---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FASTENER_ICON_CATEGORIES, fastenerIconManifest, renderFastenerShapeIcon } from '../lib/fastener-icons';

const sections = FASTENER_ICON_CATEGORIES.map((category) => ({
  category,
  icons: fastenerIconManifest
    .filter((entry) => entry.category === category)
    .map((entry) => ({
      ...entry,
      markup: renderFastenerShapeIcon(entry.shapeKey, {
        className: 'w-16 h-auto text-bp-text-faint',
        title: entry.shapeKey,
        decorative: false,
      }),
    })),
}));
---

<BaseLayout title="Fastener Icons">
  <div class="max-w-6xl mx-auto px-4 py-16 space-y-12">
    <div class="max-w-3xl">
      <h1 class="text-4xl font-bold mb-4">
        Fastener <span class="text-accent-400">Icon Library</span>
      </h1>
      <p class="text-bp-text-muted">
        QA view for the raw SVG asset set in <code>icons/fasteners</code>. Alias entries are listed alongside canonical shapes so the manifest can be reviewed visually.
      </p>
    </div>

    {sections.map((section) => (
      <section class="space-y-4">
        <h2 class="text-2xl font-semibold capitalize">{section.category}</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {section.icons.map((icon) => (
            <article class="rounded-lg border border-bp-700 bg-bp-900/60 p-4">
              <div class="flex justify-center items-center min-h-32">
                {icon.markup && <Fragment set:html={icon.markup} />}
              </div>
              <div class="border-t border-bp-700 pt-3 space-y-1">
                <p class="font-mono text-sm text-bp-text">{icon.shapeKey}</p>
                <p class="text-xs text-bp-text-muted">{icon.viewBox}</p>
                {'sameAs' in icon && (
                  <p class="text-xs text-accent-300">alias of {icon.sameAs}</p>
                )}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
