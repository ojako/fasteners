---
import { renderFastenerIcon, type FastenerIconCategory } from '../lib/fastener-icons';

interface Props {
  slug: string;
  category: FastenerIconCategory;
  class?: string;
  title?: string;
  decorative?: boolean;
}

const { slug, category, class: className = '', title, decorative = true } = Astro.props;
const svgMarkup = renderFastenerIcon({ slug, category, className, title, decorative });
---

{svgMarkup && <Fragment set:html={svgMarkup} />}
